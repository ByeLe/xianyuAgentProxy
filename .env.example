PORT=7892

# Docker Compose 暴露到宿主机的 Node apiproxy 端口。
AGENT_PROXY_PORT=7894
XIANYU_BRIDGE_PORT=7893

# agent / botmux 回调本服务时使用的外部地址。
PUBLIC_BASE_URL=http://127.0.0.1:7894

# 话题群 Webhook。正式使用前建议重新生成令牌，不要提交到仓库。
# 如果 botmux webhook 服务跑在同一台 Mac，Docker 容器内通常要用 host.docker.internal 访问宿主机。
# 示例：http://host.docker.internal:7891/webhook/xxx/yyy
TOPIC_WEBHOOK_URL=

# Python XianYuApis 侧的发信接口，由 Python 常驻 WebSocket 进程实现。
XIANYU_SEND_URL=http://127.0.0.1:7893/xianyu/send

# 可选：apiproxy 调用 Python /xianyu/send 时携带 Authorization: Bearer <token>
XIANYU_SEND_TOKEN=

# 可选：XianYuApis 调用 /xianyu/message 时携带 Authorization: Bearer <token>
XIANYU_INBOUND_TOKEN=

# 可选：agent 调用 /agent/reply 时携带 Authorization: Bearer <token>
AGENT_REPLY_TOKEN=

REQUEST_TIMEOUT_MS=20000
SESSION_TTL_MS=86400000
BOTMUX_SESSION_STORE_PATH=./work/botmux-sessions.json

# 可选：启用 botmux relay 中转方案。需要运行环境能执行 botmux CLI。
BOTMUX_RELAY_ENABLED=false
BOTMUX_COMMAND=botmux
BOTMUX_SEND_TIMEOUT_MS=15000
BOTMUX_RELAY_LOOKUP_TIMEOUT_MS=5000
BOTMUX_RELAY_LOOKUP_INTERVAL_MS=250

# relay 初始化后，如果 botmux send 没直接返回“用户的嘴替”的 sessionId，
# 服务会从 botmux 本地会话文件里按 conversation_key 查询。
# 首条普通 webhook 如果没直接返回“哈喽哈”的 sessionId，
# 服务也会从哈喽哈本地会话文件里按 conversation_key 查询。
BOTMUX_DATA_DIR=
BOTMUX_RELAY_APP_ID=
BOTMUX_TARGET_APP_ID=
BOTMUX_RELAY_SESSIONS_PATH=
BOTMUX_TARGET_SESSIONS_PATH=

# 用户的嘴替 / 哈喽哈的 botmux mention 参数，格式为 open_id:名称。
BOTMUX_RELAY_MENTION=
BOTMUX_TARGET_MENTION=
BOTMUX_TARGET_NAME=哈喽哈

# 本地联调时可以设为 true，这样 /agent/reply 不会真的调用 XIANYU_SEND_URL。
MOCK_XIANYU_SEND=false

# Python 闲鱼桥接容器需要的登录 cookie。不要提交真实值。
XIANYU_COOKIES=
